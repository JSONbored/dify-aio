#!/command/with-contenv bash
set -euo pipefail

# shellcheck source=/dev/null
. /opt/dify-aio/lib/env.sh
load_generated_env
configure_dify_env

if ! is_true "${DIFY_USE_INTERNAL_REDIS:-true}"; then
	aio_log "External Redis mode enabled; keeping bundled Redis idle."
	exec sleep infinity
fi

exec redis-server --bind 127.0.0.1 --port "${REDIS_PORT}" --dir /appdata/redis --appendonly yes --requirepass "${REDIS_PASSWORD}"
